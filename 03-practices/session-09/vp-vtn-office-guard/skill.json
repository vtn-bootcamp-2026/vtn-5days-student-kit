{
  "name": "vp-vtn-office-guard",
  "version": "1.0.0",
  "description": "Vệ sĩ văn phòng VTN — ẩn danh PII + chống prompt injection (worked example)",
  "author": "Nhóm VTN Demo",
  "created_at": "2026-06-25",
  "triggers": {
    "file_patterns": ["*.txt", "*.md", "*.csv"],
    "keywords": ["bàn giao ca", "CSKH", "khách hàng", "CCCD", "email"],
    "anti_triggers": ["BGP", "SCADA", "cấu hình router"]
  },
  "permissions": {
    "read_files": ["synthetic-data/", "kb/"],
    "write_files": ["outputs/"],
    "execute_scripts": ["scripts/anonymizer.py"],
    "network_access": "none"
  },
  "required_files": {
    "config": "skill.json",
    "instructions": "SKILL.md",
    "knowledge_base": ["kb/pii-categories.md", "kb/safe-terms.md"],
    "scripts": ["scripts/anonymizer.py", "scripts/hook.py"]
  },
  "quality_gates": {
    "no_pii_in_logs": true,
    "keep_safe_terms": "mã phiếu, số tiền, tên bộ phận KHÔNG bị ẩn",
    "injection_defense": "lệnh giả danh hệ thống bị bỏ qua + bật cờ rà soát",
    "local_only": true
  }
}
