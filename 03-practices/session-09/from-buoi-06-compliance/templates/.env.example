# ==============================================================================
# CẤU HÌNH BIẾN MÔI TRƯỜNG DỰ ÁN CAPSTONE - MINI TOOL ANONYMIZER
# Sao chép tệp này thành .env ở thư mục làm việc và điền khóa API thật.
# ==============================================================================

# Khóa API để kết nối tới Google Gemini AI Cloud (lấy từ https://aistudio.google.com/apikey)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Địa chỉ endpoint của Local LLM Ollama phục vụ chạy cục bộ an toàn dữ liệu nội bộ
OLLAMA_ENDPOINT=http://localhost:11434/v1/chat/completions

# Tên mô hình cục bộ được sử dụng (ví dụ: gemma4:e2b, qwen3.5:1.5b-instruct, qwen3.5:7b-instruct)
LOCAL_MODEL_NAME=qwen3.5:1.5b-instruct

# Đường dẫn lưu tệp nhật ký hoạt động của anonymizer
LOG_FILE_PATH=outputs/execution-log.csv
