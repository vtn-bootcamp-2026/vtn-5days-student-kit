{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Capstone Grading Result",
  "description": "Schema kết quả đánh giá chi tiết dự án Capstone của nhóm",
  "type": "object",
  "required": [
    "group_id",
    "grader_name",
    "evaluation_date",
    "rubric_type",
    "main_criteria",
    "bonus_criteria",
    "total_score",
    "final_classification",
    "general_comment"
  ],
  "properties": {
    "group_id": {
      "type": "string",
      "description": "Mã định danh của nhóm học viên"
    },
    "grader_name": {
      "type": "string",
      "description": "Tên giảng viên / giám khảo chấm điểm"
    },
    "evaluation_date": {
      "type": "string",
      "format": "date",
      "description": "Ngày thực hiện đánh giá"
    },
    "rubric_type": {
      "type": "string",
      "enum": ["100_point", "50_point"],
      "description": "Loại rubric được sử dụng (100 điểm hoặc 50 điểm)"
    },
    "main_criteria": {
      "type": "object",
      "required": ["blueprint_overall", "logical_workflow", "core_prompt", "action_plan", "presentation"],
      "properties": {
        "blueprint_overall": {
          "type": "object",
          "required": ["score", "confidence_score", "evidence", "comments"],
          "properties": {
            "score": {"type": "number", "description": "Điểm số tiêu chí Blueprint tổng quan"},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0, "description": "Độ tin cậy của AI khi chấm tiêu chí này (0.0 đến 1.0)"},
            "evidence": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["file", "quote", "description"],
                "properties": {
                  "file": {"type": "string", "description": "Tên file bài nộp (vd: 01-use-case-one-pager.md)"},
                  "quote": {"type": "string", "description": "Đoạn văn trích dẫn nguyên văn từ file làm minh chứng"},
                  "description": {"type": "string", "description": "Mô tả lý do trích dẫn hoặc ý nghĩa minh chứng"}
                }
              }
            },
            "comments": {"type": "string", "description": "Nhận xét chi tiết"}
          }
        },
        "logical_workflow": {
          "type": "object",
          "required": ["score", "confidence_score", "evidence", "comments"],
          "properties": {
            "score": {"type": "number", "description": "Điểm số tiêu chí Luồng logic"},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0, "description": "Độ tin cậy của AI khi chấm tiêu chí này (0.0 đến 1.0)"},
            "evidence": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["file", "quote", "description"],
                "properties": {
                  "file": {"type": "string"},
                  "quote": {"type": "string"},
                  "description": {"type": "string"}
                }
              }
            },
            "comments": {"type": "string"}
          }
        },
        "core_prompt": {
          "type": "object",
          "required": ["score", "confidence_score", "evidence", "comments"],
          "properties": {
            "score": {"type": "number", "description": "Điểm số tiêu chí Lời nhắc bền vững"},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0, "description": "Độ tin cậy của AI khi chấm tiêu chí này (0.0 đến 1.0)"},
            "evidence": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["file", "quote", "description"],
                "properties": {
                  "file": {"type": "string"},
                  "quote": {"type": "string"},
                  "description": {"type": "string"}
                }
              }
            },
            "comments": {"type": "string"}
          }
        },
        "action_plan": {
          "type": "object",
          "required": ["score", "confidence_score", "evidence", "comments"],
          "properties": {
            "score": {"type": "number", "description": "Điểm số tiêu chí Lộ trình khả thi"},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0, "description": "Độ tin cậy của AI khi chấm tiêu chí này (0.0 đến 1.0)"},
            "evidence": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["file", "quote", "description"],
                "properties": {
                  "file": {"type": "string"},
                  "quote": {"type": "string"},
                  "description": {"type": "string"}
                }
              }
            },
            "comments": {"type": "string"}
          }
        },
        "presentation": {
          "type": "object",
          "required": ["score", "confidence_score", "evidence", "comments"],
          "properties": {
            "score": {"type": "number", "description": "Điểm số tiêu chí Slide và thuyết trình"},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0, "description": "Độ tin cậy của AI khi chấm tiêu chí này (0.0 đến 1.0)"},
            "evidence": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["file", "quote", "description"],
                "properties": {
                  "file": {"type": "string"},
                  "quote": {"type": "string"},
                  "description": {"type": "string"}
                }
              }
            },
            "comments": {"type": "string"}
          }
        }
      }
    },
    "bonus_criteria": {
      "type": "object",
      "required": ["source_code_testing", "safety_logging"],
      "properties": {
        "source_code_testing": {
          "type": "object",
          "required": ["score", "confidence_score", "evidence", "comments"],
          "properties": {
            "score": {"type": "number", "description": "Điểm cộng phần Mã nguồn và kiểm thử"},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0, "description": "Độ tin cậy của AI khi chấm tiêu chí này (0.0 đến 1.0)"},
            "evidence": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["file", "quote", "description"],
                "properties": {
                  "file": {"type": "string"},
                  "quote": {"type": "string"},
                  "description": {"type": "string"}
                }
              }
            },
            "comments": {"type": "string"}
          }
        },
        "safety_logging": {
          "type": "object",
          "required": ["score", "confidence_score", "evidence", "comments"],
          "properties": {
            "score": {"type": "number", "description": "Điểm cộng phần An toàn bảo mật và logging"},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0, "description": "Độ tin cậy của AI khi chấm tiêu chí này (0.0 đến 1.0)"},
            "evidence": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["file", "quote", "description"],
                "properties": {
                  "file": {"type": "string"},
                  "quote": {"type": "string"},
                  "description": {"type": "string"}
                }
              }
            },
            "comments": {"type": "string"}
          }
        }
      }
    },
    "total_score": {
      "type": "number",
      "description": "Tổng điểm số phần chính của nhóm (không vượt quá điểm tối đa của rubric)"
    },
    "final_classification": {
      "type": "string",
      "enum": ["Xuất sắc", "Đạt", "Cần bổ sung", "Chưa đạt"],
      "description": "Xếp loại cuối khóa"
    },
    "general_comment": {
      "type": "string",
      "description": "Nhận xét tổng quát của giám khảo"
    }
  }
}
