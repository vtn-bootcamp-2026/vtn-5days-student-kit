{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Capstone Group Submission Status",
  "description": "Schema lưu trữ hiện trạng bài nộp của một nhóm học viên",
  "type": "object",
  "required": ["group_id", "confidence_score", "blueprint_files", "implementation_files", "logs_and_configs"],
  "properties": {
    "group_id": {
      "type": "string",
      "description": "Mã định danh của nhóm (vd: nhom-01)"
    },
    "confidence_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Độ tin cậy tổng thể của bước Intake"
    },
    "blueprint_files": {
      "type": "object",
      "required": ["one_pager", "logical_workflow", "core_prompt_design", "compliance_checklist", "action_plan"],
      "properties": {
        "one_pager": {
          "type": "object",
          "required": ["exists", "word_count", "contains_placeholders", "confidence_score"],
          "properties": {
            "exists": {"type": "boolean"},
            "word_count": {"type": "integer"},
            "contains_placeholders": {"type": "boolean"},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0},
            "key_details_extracted": {
              "type": "object",
              "properties": {
                "use_case_name": {"type": "string"},
                "target_users": {"type": "array", "items": {"type": "string"}},
                "kpis": {"type": "array", "items": {"type": "string"}}
              }
            }
          }
        },
        "logical_workflow": {
          "type": "object",
          "required": ["exists", "has_mermaid", "contains_placeholders", "confidence_score"],
          "properties": {
            "exists": {"type": "boolean"},
            "has_mermaid": {"type": "boolean"},
            "contains_placeholders": {"type": "boolean"},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0},
            "hitl_points": {"type": "array", "items": {"type": "string"}}
          }
        },
        "core_prompt_design": {
          "type": "object",
          "required": ["exists", "contains_placeholders", "confidence_score"],
          "properties": {
            "exists": {"type": "boolean"},
            "contains_placeholders": {"type": "boolean"},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0},
            "system_prompt_length": {"type": "integer"},
            "output_format": {"type": "string"}
          }
        },
        "compliance_checklist": {
          "type": "object",
          "required": ["exists", "items_checked_count", "contains_placeholders", "confidence_score"],
          "properties": {
            "exists": {"type": "boolean"},
            "items_checked_count": {"type": "integer"},
            "contains_placeholders": {"type": "boolean"},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0}
          }
        },
        "action_plan": {
          "type": "object",
          "required": ["exists", "contains_placeholders", "confidence_score"],
          "properties": {
            "exists": {"type": "boolean"},
            "contains_placeholders": {"type": "boolean"},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0},
            "has_30_days": {"type": "boolean"},
            "has_90_days": {"type": "boolean"}
          }
        }
      }
    },
    "implementation_files": {
      "type": "object",
      "required": ["anonymizer_py", "test_anonymizer_py"],
      "properties": {
        "anonymizer_py": {
          "type": "object",
          "required": ["exists", "contains_functions", "confidence_score"],
          "properties": {
            "exists": {"type": "boolean"},
            "contains_functions": {"type": "array", "items": {"type": "string"}},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0}
          }
        },
        "test_anonymizer_py": {
          "type": "object",
          "required": ["exists", "test_count", "confidence_score"],
          "properties": {
            "exists": {"type": "boolean"},
            "test_count": {"type": "integer"},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0}
          }
        }
      }
    },
    "logs_and_configs": {
      "type": "object",
      "required": ["execution_log_csv", "env_file", "skill_json", "skill_md"],
      "properties": {
        "execution_log_csv": {
          "type": "object",
          "required": ["exists", "lines_count", "confidence_score"],
          "properties": {
            "exists": {"type": "boolean"},
            "lines_count": {"type": "integer"},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0}
          }
        },
        "env_file": {
          "type": "object",
          "required": ["exists", "contains_keys", "confidence_score"],
          "properties": {
            "exists": {"type": "boolean"},
            "contains_keys": {"type": "array", "items": {"type": "string"}},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0}
          }
        },
        "skill_json": {
          "type": "object",
          "required": ["exists", "confidence_score"],
          "properties": {
            "exists": {"type": "boolean"},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0}
          }
        },
        "skill_md": {
          "type": "object",
          "required": ["exists", "confidence_score"],
          "properties": {
            "exists": {"type": "boolean"},
            "confidence_score": {"type": "number", "minimum": 0.0, "maximum": 1.0}
          }
        }
      }
    }
  }
}
