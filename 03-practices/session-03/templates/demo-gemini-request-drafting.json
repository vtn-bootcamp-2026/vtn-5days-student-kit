    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const raw = $json.raw_ai_output || $json.text || $json.output || $json.response || \"\";\nlet cleaned = String(raw).replace(/```json/gi, \"\").replace(/```/g, \"\").trim();\nconst firstBrace = cleaned.indexOf(\"{\");\nconst lastBrace = cleaned.lastIndexOf(\"}\");\nif (firstBrace !== -1 && lastBrace > firstBrace) cleaned = cleaned.slice(firstBrace, lastBrace + 1);\n\nlet parsed;\ntry {\n  parsed = JSON.parse(cleaned);\n} catch (error) {\n  parsed = {\n    phan_loai: \"Khac\",\n    muc_do: \"Trung_binh\",\n    tom_tat: \"AI trả về dữ liệu chưa đúng định dạng.\",\n    du_thao_phan_hoi: \"Yêu cầu đã được ghi nhận và chuyển người phụ trách kiểm tra thủ công.\",\n    can_con_nguoi_duyet: true,\n    parse_error: error.message\n  };\n}\n\nconst review = parsed.can_con_nguoi_duyet === true || parsed.can_con_nguoi_duyet === \"true\";\nconst redact = (text) => String(text || \"\").replace(/(mat khau|mật khẩu|password|pwd|token|api key)[:\\s]+([^\\s,;]+)/gi, \"$1: [REDACTED]\");\n\nreturn {\n  json: {\n    ...$json,\n    phan_loai: parsed.phan_loai || \"Khac\",\n    muc_do_ai: parsed.muc_do || \"Trung_binh\",\n    tom_tat: redact(parsed.tom_tat),\n    du_thao_phan_hoi: redact(parsed.du_thao_phan_hoi),\n    can_con_nguoi_duyet: review,\n    trang_thai_du_thao: \"Can_duyet\",\n    parse_error: parsed.parse_error || \"\",\n    xu_ly_luc: $now.toFormat(\"yyyy-MM-dd HH:mm\")\n  }\n};"
      },
