    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "mode": "list",
          "value": "models/gemini-3.5-flash"
        },
        "messages": {
          "values": [
            {
              "content": "Bạn là trợ lý xử lý yêu cầu nội bộ cho doanh nghiệp viễn thông.\n\nHãy phân loại yêu cầu vào đúng một nhóm: Hanh_chinh, Nhan_su, CNTT, Ke_toan, Khac.\nĐánh giá mức độ: Thap, Trung_binh, Cao.\nSoạn dự thảo phản hồi bằng tiếng Việt, dài 2-4 câu, lịch sự, rõ bước tiếp theo.\nKhông tự cam kết thời hạn, chi phí, phê duyệt hoặc quyết định thay con người.\nNếu nội dung mơ hồ, chứa dữ liệu nhạy cảm, yêu cầu chi tiền hoặc cần quyết định quản lý, đặt can_con_nguoi_duyet = true.\n\nChỉ trả về JSON thuần, không markdown, đúng 5 trường:\n{\n  \"phan_loai\": \"Hanh_chinh | Nhan_su | CNTT | Ke_toan | Khac\",\n  \"muc_do\": \"Thap | Trung_binh | Cao\",\n  \"tom_tat\": \"tóm tắt dưới 25 từ\",\n  \"du_thao_phan_hoi\": \"bản nháp để con người duyệt\",\n  \"can_con_nguoi_duyet\": true\n}",
              "role": "model"
            },
            {
              "content": "=Mã yêu cầu: {{ $json.ma_yeu_cau }}\nĐơn vị: {{ $json.don_vi }}\nKênh phản hồi mong muốn: {{ $json.kenh_phan_hoi }}\nNội dung yêu cầu: {{ $json.noi_dung }}\n\nHãy phân loại và soạn bản nháp.",
              "role": "user"
            }
          ]
        },
        "builtInTools": {},
        "options": {
          "temperature": 0.2
        }
      },
